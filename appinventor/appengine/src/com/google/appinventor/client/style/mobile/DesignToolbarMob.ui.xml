<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui"
             xmlns:ca="urn:import:com.google.appinventor.client.actions"
             xmlns:ai="urn:import:com.google.appinventor.client.widgets"
             xmlns:ya="urn:import:com.google.appinventor.client.editor.youngandroid.actions"
             ui:generatedFormat="com.google.gwt.i18n.server.PropertyCatalogFactory"
             ui:generatedKeys="com.google.gwt.i18n.server.keygen.MethodNameKeyGenerator"
             ui:generateLocales="default">
    <ui:with field="messages" type="com.google.appinventor.client.OdeMessages"/>
    <ai:Toolbar styleName="Ode-designerToolbar">
        <!-- Left button items -->
        <ai:ToolbarItem name="myProjects" icon="arrow_back" align="left" styleName="ode-ProjectListButton DesignerBackButton" tooltip="{messages.myProjectsButton}" >
            <ca:SwitchToProjectAction/>
        </ai:ToolbarItem>

        <g:Label ui:field="projectNameLabel" styleName="ya-ProjectName" horizontalAlignment="center"/>

        <ai:ToolbarItem styleName="ya-ProjectName" caption="Screens: " align="center" enabled="false" visible="false"/>
        <ai:DropDownButton name="ScreensDropdown" caption="{messages.screensButton}"
                           ui:field="pickFormItem" align="center" styleName="ode-ProjectListButton inline bleft primary"/>
        <ai:ToolbarItem name="AddForm" icon="add" ui:field="addFormItem"
                        align="center" styleName="ode-ProjectListButton inline bcenter primary"
                        tooltip="{messages.addFormButton}">
            <ya:AddFormAction/>
        </ai:ToolbarItem>
        <ai:ToolbarItem name="RemoveForm" icon="remove" ui:field="removeFormItem"
                        align="center" styleName="ode-ProjectListButton inline bright primary"
                        tooltip="{messages.removeFormButton}">
            <ya:RemoveFormAction/>
        </ai:ToolbarItem>
      <ai:DropDownButton name="MobileDropdown" icon="more_vert" styleName="ode-ProjectListButton inline" align="center" rightAlign="true" >
        <ai:DropDownItem name="ProjectProperties" caption="{messages.projectPropertiesText}" styleName="mobile-dropdown-button">
          <ya:ProjectPropertiesAction />
        </ai:DropDownItem>
        <ai:DropDownItem name="SendToGallery" caption="{messages.publishToGalleryButton}"
            styleName="mobile-dropdown-button">
          <ca:SendToGalleryAction />
        </ai:DropDownItem>
      </ai:DropDownButton>

      <ai:ToolbarItem name="SendToGalleryHidden" ui:field="sendToGalleryItem" visible="false" />

      <ai:ToolbarItem name="SwitchToDesign" icon="draft" align="right" styleName="ode-ProjectListButton DesignerBackButton" ui:field="switchToDesign" tooltip="{messages.switchToFormEditorButton}"  >
        <ya:SwitchToFormEditorAction />
      </ai:ToolbarItem>
      <ai:ToolbarItem name="SwitchToBlocks" icon="view_comfy_alt" align="right" styleName="ode-ProjectListButton DesignerBackButton" ui:field="switchToBlocks" tooltip="{messages.switchToBlocksEditorButton}"  >
        <ya:SwitchToBlocksEditorAction />
      </ai:ToolbarItem>


<!--      <ai:DropDownButton name="MobileDropdown" icon="more_vert" styleName="ode-ProjectListButton DesignerBackButton" align="right" rightAlign="true" >-->
